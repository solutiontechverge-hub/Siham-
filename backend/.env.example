# Copy to .env and fill in real values. Never commit .env.

PORT=5000

# Postgres (Supabase / Railway / local). Use DATABASE_URL or DB_URL.
DB_URL=postgresql://postgres:postgres@localhost:5432/mollure_db
# DATABASE_URL=

# Supabase pooler usually needs SSL (also auto-detected if host contains supabase.co)
# DB_SSL=true
# PGSSLMODE=require

JWT_SECRET=your_jwt_secret_min_32_chars_recommended
JWT_REFRESH_SECRET=your_refresh_secret

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_app_password
SMTP_FROM=no-reply@example.com

# Public URL of this API (password reset links, etc.)
# Local:
APP_BASE_URL=http://localhost:5000
# Vercel (example):
# APP_BASE_URL=https://your-backend.vercel.app

# Optional: S3 for durable uploads (not wired in multer yet — disk /tmp on Vercel)
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
