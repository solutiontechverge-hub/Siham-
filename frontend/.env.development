# Local backend → uses your live Supabase DB from backend/.env (recommended for dev)
NEXT_PUBLIC_API_USE_PROXY=false
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Optional: proxy to Vercel instead (requires VERCEL_PROTECTION_BYPASS in .env.local)
# NEXT_PUBLIC_API_USE_PROXY=true
# NEXT_PUBLIC_API_PROXY_TARGET=https://siham-x1lo-git-main-techvergesolutions-projects.vercel.app
